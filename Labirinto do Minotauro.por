programa {
  funcao inicio() {
    caracter caminho1, caminho2
     escreva("escolha o primeiro caminho: ")
     leia(caminho1)
     escreva("escolha o segundo caminho: ")
     leia(caminho2)

     se (caminho1 == 'N' e caminho2 == 'O'){
     escreva("Saída")
     }
    senao{
     escreva("Minotauro")
    }

  }
}
