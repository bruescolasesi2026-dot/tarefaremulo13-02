programa {
  funcao inicio() {
    
   caracter select

  escreva("digite \nZ para Zíngaro \nX para Xarope \nK Kryptonita:  ")
  leia(select)
  escolha(select){
    caso 'Z': 
    {
      escreva("Zíngaro")
      pare
    }
    caso 'X':
    {
      escreva("Xarope")
      pare
    }
    caso 'K':
    {
     escreva("Kryptonita")
     pare
    }
     
  }
 
  

  
  }
}
